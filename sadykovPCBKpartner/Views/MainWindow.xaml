<Window x:Class="sadykovPCBKpartner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ПЦБК — Партнёры"
        Height="660" Width="1150"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <Style x:Key="PartnerCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Margin"          Value="0,0,0,4"/>
            <Setter Property="Padding"         Value="12,9"/>
            <Setter Property="BorderBrush"     Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#222222"/>
        </Style>
        <Style x:Key="CardSubStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin"     Value="0,1,0,0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#EEEEEE"/>
            <Setter Property="Foreground"      Value="#333333"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="BorderBrush"     Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="RowBackground"            Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="BorderBrush"              Value="#CCCCCC"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEEEEE"/>
            <Setter Property="SelectionMode"            Value="Single"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- СТРОКА МЕНЮ -->
        <Menu DockPanel.Dock="Top"
              Background="White"
              BorderBrush="#DDDDDD"
              BorderThickness="0,0,0,1"
              FontSize="13">

            <MenuItem Header="Партнёры">
                <MenuItem x:Name="MenuAddPartner"    Header="Добавить партнёра"      Click="MenuAddPartner_Click"/>
                <MenuItem x:Name="MenuEditPartner"   Header="Редактировать партнёра" Click="MenuEditPartner_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuDeletePartner" Header="Удалить партнёра"       Click="MenuDeletePartner_Click"/>
            </MenuItem>

            <MenuItem Header="Продукты">
                <MenuItem x:Name="MenuAddProduct"    Header="Добавить продукт"       Click="MenuAddProduct_Click"/>
                <MenuItem x:Name="MenuEditProduct"   Header="Редактировать продукт"  Click="MenuEditProduct_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuDeleteProduct" Header="Удалить продукт"        Click="MenuDeleteProduct_Click"/>
            </MenuItem>

            <MenuItem Header="Реализация">
                <MenuItem Header="Добавить реализацию" Click="MenuAddSale_Click"/>
            </MenuItem>

            <MenuItem Header="Программа">
                <MenuItem Header="Выход" Click="MenuExit_Click"/>
            </MenuItem>
        </Menu>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ: список партнёров -->
            <DockPanel Grid.Column="0" Background="#F7F7F7">
                <Border DockPanel.Dock="Top"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <TextBlock Text="Список партнёров"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <ListBox x:Name="PartnersListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="PartnersListBox_SelectionChanged"
                             MouseDoubleClick="PartnersListBox_MouseDoubleClick">

                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Добавить партнёра"   Click="MenuAddPartner_Click"/>
                                <MenuItem Header="Редактировать"       Click="MenuEditPartner_Click"/>
                                <MenuItem Header="Удалить партнёра"    Click="MenuDeletePartner_Click"/>
                                <Separator/>
                                <MenuItem Header="Добавить реализацию" Click="MenuAddSale_Click"/>
                                <MenuItem Header="История реализации"  Click="MenuShowHistory_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PartnerCardStyle}" Width="262">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding CardTitle, Mode=OneWay}"
                                                       Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="{Binding Director, Mode=OneWay}"
                                                       Style="{StaticResource CardSubStyle}"/>
                                            <TextBlock Text="{Binding Phone, Mode=OneWay}"
                                                       Style="{StaticResource CardSubStyle}"/>
                                            <TextBlock Style="{StaticResource CardSubStyle}">
                                                <Run Text="Рейтинг: "/>
                                                <Run Text="{Binding Rating, Mode=OneWay}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="#F0F0F0"
                                                BorderBrush="#CCCCCC"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="4,2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DiscountDisplay, Mode=OneWay}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#444444"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding"         Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#DDDDDD" ShowsPreview="True"/>

            <!-- ПРАВАЯ ПАНЕЛЬ: история + продукты -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- История реализации -->
                <DockPanel Grid.Row="0">
                    <Border DockPanel.Dock="Top"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock x:Name="SalesHistoryHeader"
                                   Text="Выберите партнёра для просмотра истории реализации"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#333333"/>
                    </Border>
                    <DataGrid x:Name="SalesDataGrid" Margin="12,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Наименование продукции"
                                                Binding="{Binding Product.ProductName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Тип"
                                                Binding="{Binding Product.ProductType}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Количество"
                                                Binding="{Binding Quantity, StringFormat=N0}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Дата продажи"
                                                Binding="{Binding SaleDate, StringFormat=dd.MM.yyyy}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <GridSplitter Grid.Row="1" Height="5"
                              HorizontalAlignment="Stretch"
                              Background="#DDDDDD" ShowsPreview="True"/>

                <!-- Продукты -->
                <DockPanel Grid.Row="2">
                    <Border DockPanel.Dock="Top"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock Text="Продукция"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#333333"/>
                    </Border>
                    <DataGrid x:Name="ProductsDataGrid"
                              Margin="12,10"
                              MouseDoubleClick="ProductsDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул"
                                                Binding="{Binding Article}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Наименование"
                                                Binding="{Binding ProductName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Тип"
                                                Binding="{Binding ProductType}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Мин. цена (руб.)"
                                                Binding="{Binding MinPrice, StringFormat=N2}"
                                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
