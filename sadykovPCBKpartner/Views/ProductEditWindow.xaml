<Window x:Class="sadykovPCBKpartner.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="380" Width="460"
        MinHeight="360" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin"     Value="0,10,0,3"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="7,4"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Width"           Value="110"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="White" Margin="0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16">

                <TextBlock x:Name="FormTitleBlock"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#222222"
                           Margin="0,0,0,14"/>

                <TextBlock Text="Артикул *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="ArticleTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="50"
                         ToolTip="Уникальный артикул продукта (до 50 символов)"/>

                <TextBlock Text="Наименование *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="ProductNameTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="255"
                         ToolTip="Полное наименование продукта"/>

                <TextBlock Text="Тип продукта *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="ProductTypeTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="100"
                         ToolTip="Например: Ламинат, Паркет, Плитка"/>

                <TextBlock Text="Минимальная цена (руб.) *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="MinPriceTextBox"
                         Style="{StaticResource InputStyle}"
                         MaxLength="12"
                         ToolTip="Минимальная цена для партнёра в рублях (например: 850.00)"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button x:Name="SaveButton"
                            Content="Сохранить"
                            Style="{StaticResource BtnStyle}"
                            Background="#444444"
                            Foreground="White"
                            BorderBrush="#444444"
                            Click="SaveButton_Click"
                            Margin="0,0,10,0"/>
                    <Button Content="Отмена"
                            Style="{StaticResource BtnStyle}"
                            Background="White"
                            Foreground="#555555"
                            BorderBrush="#BBBBBB"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
