<Window x:Class="sadykovPCBKpartner.Views.SaleAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление реализации продукции"
        Height="400" Width="480"
        MinHeight="380" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin"     Value="0,10,0,3"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="7,4"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Width"           Value="110"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="White">
        <DockPanel>

            <!-- Заголовок -->
            <Border DockPanel.Dock="Top"
                    Background="#F7F7F7"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1"
                    Padding="20,12">
                <TextBlock Text="Новая запись о реализации продукции"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#222222"/>
            </Border>

            <!-- Кнопки снизу -->
            <Border DockPanel.Dock="Bottom"
                    Background="#F7F7F7"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0"
                    Padding="20,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить"
                            Style="{StaticResource BtnStyle}"
                            Background="#444444"
                            Foreground="White"
                            BorderBrush="#444444"
                            Click="SaveButton_Click"
                            Margin="0,0,8,0"/>
                    <Button Content="Отмена"
                            Style="{StaticResource BtnStyle}"
                            Background="White"
                            Foreground="#555555"
                            BorderBrush="#CCCCCC"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </Border>

            <!-- Поля -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,8,20,16">

                    <TextBlock Text="Партнёр *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="PartnerComboBox"
                              Height="30" FontSize="13"
                              Background="White"
                              BorderBrush="#BBBBBB"
                              DisplayMemberPath="CompanyName"
                              SelectedValuePath="Id"
                              ToolTip="Выберите партнёра из списка"/>

                    <TextBlock Text="Фильтр продукта по артикулу" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="ArticleFilterTextBox"
                             Style="{StaticResource InputStyle}"
                             MaxLength="50"
                             ToolTip="Введите часть артикула для фильтрации"
                             TextChanged="ArticleFilterTextBox_TextChanged"/>

                    <TextBlock Text="Продукт *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ProductComboBox"
                              Height="30" FontSize="13"
                              Background="White"
                              BorderBrush="#BBBBBB"
                              ToolTip="Выберите продукт из списка">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Article}" FontWeight="SemiBold"
                                               Width="80" Foreground="#555555"/>
                                    <TextBlock Text=" — "/>
                                    <TextBlock Text="{Binding ProductName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Количество и дата в одну строку -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Количество *" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="QuantityTextBox"
                                     Style="{StaticResource InputStyle}"
                                     MaxLength="10"
                                     ToolTip="Количество реализованных единиц (целое число больше 0)"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Дата реализации *" Style="{StaticResource LabelStyle}"/>
                            <DatePicker x:Name="SaleDatePicker"
                                        Height="30"
                                        FontSize="13"
                                        BorderBrush="#BBBBBB"
                                        ToolTip="Выберите дату реализации продукции"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
